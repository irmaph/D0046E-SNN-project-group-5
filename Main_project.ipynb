    "def get_input_neurons(spike_seq, dt):\n",
    "    \"\"\"\n",
    "    Converts a (T, H, W) spike sequence into a list of\n",
    "    spike_generator objects for the simulation engine.\n",
    "    \"\"\"\n",
    "    T, H, W = spike_seq.shape\n",
    "    N_synapses = H * W\n",
    "    # Flatten the spatial dimensions over time: (T, 640)\n",
    "    spikes_flat = spike_seq.reshape(T, -1)\n",
    "\n",
    "    input_neurons = []\n",
    "    for i in range(N_synapses):\n",
    "        # Find every time index where this specific pixel fired\n",
    "        spike_indices = np.where(spikes_flat[:, i] == 1)[0]\n",
    "        # Convert indices to actual simulation time: t = index * dt\n",
    "        spike_times = spike_indices * dt\n",
    "        input_neurons.append(spike_generator(spike_times))\n",
    "\n",
    "    return input_neurons\n",
    "\n",
    "\n",
    "def train_snn(x_train, y_train, epochs=3, dt=1e-4):\n",
    "    N = 10 * 64  # Total synapses for 10x64 grid\n",
    "\n",
    "    # Step A: Initialize the STDP Output Neuron\n",
    "    # Using the team's function with small initial weights\n",
    "    n_stdp = lif_stdp_neuron(num_synapses=N, w_max=2e-9, gamma=1.5)\n",
    "    n_stdp['w_syn'][:] = 100e-12\n",
    "\n",
    "    print(\"Starting Training...\")\n",
    "\n",
    "    for epoch in range(epochs):\n",
    "        for i in range(len(x_train)):\n",
    "            if y_train[i] == \"right\":\n",
    "                # 1. Convert frames to spikes\n",
    "                spike_seq = encode_to_spikes(x_train[i])\n",
    "\n",
    "                # 2. Setup the neuron population for this sample\n",
    "                input_neurons = get_input_neurons(spike_seq, dt)\n",
    "                neurons = input_neurons + [n_stdp]\n",
    "\n",
    "                # 3. Define connections [post, syn_index, pre]\n",
    "                connections = [[N, j, j] for j in range(N)]\n",
    "\n",
    "                # 4. Run the simulation for the duration of the sequence\n",
    "                T_steps = len(spike_seq)\n",
    "                for step in range(T_steps):\n",
    "                    t_current = step * dt\n",
    "                    # This calls the team's physics, spikegen, and STDP logic\n",
    "                    update(dt, t_current, neurons, connections)\n",
    "\n",
    "        print(f\"Epoch {epoch+1} complete.\")\n",
    "\n",
    "    return n_stdp['w_syn']"
