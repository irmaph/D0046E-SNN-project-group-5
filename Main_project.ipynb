   "source": [
    "## Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6d7e68b0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test set\n",
    "x_test, y_test = [], []\n",
    "\n",
    "for direction, label in [(\"right\", 1), (\"left\", 0)]:\n",
    "    x, _ = create_dataset(\n",
    "        n_samples=200,\n",
    "        direction=direction,\n",
    "        p_right=(direction == \"right\"),\n",
    "        p_left=(direction == \"left\"),\n",
    "        p_stop=0.0\n",
    "    )\n",
    "    x_test.append(x)\n",
    "    y_test.append(np.full(200, label))\n",
    "\n",
    "x_test = np.concatenate(x_test)\n",
    "y_test = np.concatenate(y_test)\n",
    "\n",
    "# Prediction function\n",
    "def predict(sequence, weights,threshold_val=9e-08, decay=0.9, spike_limit=2):\n",
    "    spikes = encode_to_spikes(sequence)\n",
    "    input_seq = spikes.reshape(len(spikes), -1)\n",
    "\n",
    "    membrane = 0.0\n",
    "    spike_count = 0\n",
    "\n",
    "    for frame in input_seq:\n",
    "        membrane = membrane * decay + np.dot(frame, weights)\n",
    "        if membrane >= threshold_val:\n",
    "            spike_count += 1\n",
    "            membrane = 0.0\n",
    "\n",
    "    # If it spikes more than 'spike_limit' times, it's 'Right' (1)\n",
    "    return 1 if spike_count >= spike_limit else 0\n",
    "\n",
    "# Compute accuracy\n",
    "\n",
    "right_preds = [predict(seq, final_weights) for seq in x_test[y_test == 1]]\n",
    "left_preds  = [predict(seq, final_weights) for seq in x_test[y_test == 0]]\n",
    "\n",
    "right_acc = np.mean(right_preds)\n",
    "left_acc  = 1 - np.mean(left_preds) # Accuracy is when 'Left' returns 0\n",
    "\n",
    "# Total Accuracy calculation\n",
    "all_preds = np.concatenate([right_preds, left_preds])\n",
    "total_accuracy = np.mean(all_preds == y_test)\n",
    "\n",
    "print(f\"--- Final Model Evaluation ---\")\n",
    "print(f\"Right Motion accuracy: {right_acc*100:.2f}%\")\n",
    "print(f\"Left Motion accuracy: {left_acc*100:.2f}%\")\n",
    "print(f\"Total test accuracy: {total_accuracy * 100:.2f}%\")"
   ]
  },
